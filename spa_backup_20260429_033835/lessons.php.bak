    <!-- JavaScript -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Global variables
        let currentPage = <?php echo $page; ?>;
        let editingLessonId = null;
        let lessonToDeleteId = null;
        let selectedSubjects = [];
        let currentStudentAssignments = {};
        let currentAcademicLevel = '<?php echo $current_level; ?>';
        let isSubmitting = false;

        // Permissions from PHP
        const PERMISSIONS = {
            canCreate: <?php echo $canCreate ? 'true' : 'false'; ?>,
            canEdit: <?php echo $canEdit ? 'true' : 'false'; ?>,
            canDelete: <?php echo $canDelete ? 'true' : 'false'; ?>,
            canAssignStudents: <?php echo $canAssignStudents ? 'true' : 'false'; ?>,
            canViewAll: <?php echo $canViewAll ? 'true' : 'false'; ?>,
            isSuperAdmin: <?php echo $isSuperAdmin ? 'true' : 'false'; ?>
        };

        // DOM Elements
        const addLessonBtn = document.getElementById('addLessonBtn');
        const lessonModal = document.getElementById('lessonModal');
        const deleteModal = document.getElementById('deleteModal');
        const closeModalBtn = document.getElementById('closeModal');
        const cancelBtn = document.getElementById('cancelBtn');
        const saveLessonBtn = document.getElementById('saveLessonBtn');
        const saveBtnText = document.getElementById('saveBtnText');
        const searchInput = document.getElementById('searchInput');
        const lessonsTableBody = document.getElementById('lessonsTableBody');
        const toastContainer = document.getElementById('toastContainer');
        const academicLevelFilter = document.getElementById('academicLevelFilter');
        const classFilter = document.getElementById('classFilter');
        const classSelect = document.getElementById('classSelect');
        const streamSelect = document.getElementById('streamSelect');
        const teacherSelect = document.getElementById('teacherSelect');
        const assignAllCheckbox = document.getElementById('assignAllStudents');
        const studentCount = document.getElementById('studentCount');
        const lessonForm = document.getElementById('lessonForm');
        const subjectButton = document.getElementById('subjectSelectButton');
        const subjectDropdown = document.getElementById('subjectDropdown');
        const tabButtons = document.querySelectorAll('.tab-button');
        const tabContents = document.querySelectorAll('.tab-content');
        const studentClassFilter = document.getElementById('studentClassFilter');
        const studentStreamFilter = document.getElementById('studentStreamFilter');
        const studentsTableHead = document.getElementById('studentsTableHead');
        const studentsTableBody = document.getElementById('studentsTableBody');
        const closeDeleteModal = document.getElementById('closeDeleteModal');
        const cancelDeleteBtn = document.getElementById('cancelDeleteBtn');
        const confirmDeleteBtn = document.getElementById('confirmDeleteBtn');

        // Toast Notification Function
        function showToast(title, message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            
            let icon = 'check';
            if (type === 'error') icon = 'exclamation-triangle';
            if (type === 'warning') icon = 'exclamation-circle';
            if (type === 'info') icon = 'info-circle';
            
            toast.innerHTML = `
                <div class="toast-icon">
                    <i class="fas fa-${icon}"></i>
                </div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-message">${message}</div>
                </div>
            `;
            
            toastContainer.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                toast.style.transition = 'all 0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }

        // Loading States
        function showLoading(button, text) {
            const originalHTML = button.innerHTML;
            button.dataset.originalHTML = originalHTML;
            button.innerHTML = `
                <div style="display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; border-top-color: white; animation: spin 1s ease-in-out infinite; margin-right: 8px;"></div>
                ${text}
            `;
            button.disabled = true;
        }
        
        function hideLoading(button) {
            if (button.dataset.originalHTML) {
                button.innerHTML = button.dataset.originalHTML;
            }
            button.disabled = false;
        }

        // Add CSS for spinner animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes spin {
                to { transform: rotate(360deg); }
            }
        `;
        document.head.appendChild(style);

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Check permission for action
        function checkPermission(action) {
            if (!PERMISSIONS[action] && !PERMISSIONS.isSuperAdmin) {
                showToast('Access Denied', 'You do not have permission to perform this action', 'error');
                return false;
            }
            return true;
        }

        // Initialize multi-select
        function initMultiSelect() {
            if (!subjectButton) return;
            
            // Toggle dropdown
            subjectButton.addEventListener('click', function(e) {
                e.stopPropagation();
                if (!this.disabled) {
                    subjectButton.classList.toggle('open');
                    subjectDropdown.classList.toggle('show');
                }
            });
            
            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!subjectButton.contains(e.target) && !subjectDropdown.contains(e.target)) {
                    subjectButton.classList.remove('open');
                    subjectDropdown.classList.remove('show');
                }
            });
            
            // Handle option selection
            subjectDropdown.addEventListener('click', function(e) {
                const option = e.target.closest('.multi-select-option');
                if (!option) return;
                
                const value = option.getAttribute('data-value');
                
                if (value === '') {
                    selectedSubjects = [];
                    updateSubjectSelection();
                } else {
                    const index = selectedSubjects.indexOf(value);
                    if (index === -1) {
                        selectedSubjects.push(value);
                    } else {
                        selectedSubjects.splice(index, 1);
                    }
                    updateSubjectSelection();
                }
            });
        }

        function updateSubjectSelection() {
            const subjectButtonText = document.getElementById('subjectButtonText');
            const subjectCountBadge = document.getElementById('subjectCountBadge');
            const subjectIdsInput = document.getElementById('subjectIds');
            
            if (subjectIdsInput) {
                subjectIdsInput.value = selectedSubjects.join(',');
            }
            
            if (selectedSubjects.length === 0) {
                subjectButtonText.textContent = '-- Select Subject(s) --';
                if (subjectCountBadge) {
                    subjectCountBadge.style.display = 'none';
                }
            } else {
                const selectedSubjectNames = Array.from(subjectDropdown.querySelectorAll('.multi-select-option'))
                    .filter(option => {
                        const value = option.getAttribute('data-value');
                        return value && selectedSubjects.includes(value);
                    })
                    .map(option => option.querySelector('.multi-select-label').textContent);
                
                if (selectedSubjectNames.length === 1) {
                    subjectButtonText.textContent = selectedSubjectNames[0];
                } else {
                    subjectButtonText.textContent = `${selectedSubjectNames.length} subjects selected`;
                }
                
                if (subjectCountBadge) {
                    subjectCountBadge.textContent = selectedSubjects.length;
                    subjectCountBadge.style.display = 'inline-block';
                }
            }
            
            subjectDropdown.querySelectorAll('.multi-select-option').forEach(option => {
                const value = option.getAttribute('data-value');
                const checkbox = option.querySelector('.multi-select-checkbox');
                
                if (value && selectedSubjects.includes(value)) {
                    checkbox.classList.add('checked');
                } else {
                    checkbox.classList.remove('checked');
                }
            });
        }

        // Function to update stats without page reload
        function updateStats() {
            if (!PERMISSIONS.canViewAll && !PERMISSIONS.isSuperAdmin) return;
            
            const totalLessonsEl = document.getElementById('totalLessons');
            const assignedTeachersEl = document.getElementById('assignedTeachers');
            const totalStudentsEl = document.getElementById('totalStudents');
            
            // Show loading state
            if (totalLessonsEl) totalLessonsEl.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            if (assignedTeachersEl) assignedTeachersEl.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            if (totalStudentsEl) totalStudentsEl.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            
            fetch('lessons.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'action=get_lessons_stats'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const stats = data.stats;
                    
                    // Animate the number updates
                    animateNumber(totalLessonsEl, stats.total_lessons);
                    animateNumber(assignedTeachersEl, stats.assigned_teachers);
                    animateNumber(totalStudentsEl, stats.total_students);
                } else {
                    // Restore original values if error
                    if (totalLessonsEl) totalLessonsEl.textContent = '0';
                    if (assignedTeachersEl) assignedTeachersEl.textContent = '0';
                    if (totalStudentsEl) totalStudentsEl.textContent = '0';
                }
            })
            .catch(error => {
                console.error('Error fetching stats:', error);
                // Restore original values if error
                if (totalLessonsEl) totalLessonsEl.textContent = '0';
                if (assignedTeachersEl) assignedTeachersEl.textContent = '0';
                if (totalStudentsEl) totalStudentsEl.textContent = '0';
            });
        }

        // Helper function for smooth number animation
        function animateNumber(element, targetValue) {
            if (!element) return;
            
            const currentValue = parseInt(element.textContent) || 0;
            const duration = 500; // Animation duration in milliseconds
            const steps = 20;
            const increment = (targetValue - currentValue) / steps;
            let currentStep = 0;
            
            const timer = setInterval(() => {
                currentStep++;
                if (currentStep >= steps) {
                    element.textContent = targetValue.toLocaleString();
                    clearInterval(timer);
                } else {
                    const value = Math.round(currentValue + (increment * currentStep));
                    element.textContent = value.toLocaleString();
                }
            }, duration / steps);
        }

        // Load classes based on academic level
        function loadClasses(academicLevel, targetElement, selectedClassId = null, callback = null) {
            if (!targetElement) return;
            
            targetElement.disabled = true;
            targetElement.innerHTML = '<option value="">-- Loading classes... --</option>';
            
            fetch('lessons.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `action=get_classes_by_level&academic_level=${encodeURIComponent(academicLevel)}`
            })
            .then(response => {
                if (!response.ok) throw new Error('Network response was not ok');
                return response.json();
            })
            .then(data => {
                if (data.success && data.classes && data.classes.length > 0) {
                    targetElement.innerHTML = '<option value="">-- Select Class --</option>';
                    data.classes.forEach(cls => {
                        const option = document.createElement('option');
                        option.value = cls.id;
                        option.textContent = cls.class_level;
                        if (selectedClassId && cls.id == selectedClassId) {
                            option.selected = true;
                        }
                        targetElement.appendChild(option);
                    });
                    targetElement.disabled = false;
                    
                    if (callback) {
                        callback();
                    }
                } else {
                    targetElement.innerHTML = '<option value="">-- No classes found --</option>';
                    showToast('No classes found for this academic level', 'warning');
                    if (callback) callback();
                }
            })
            .catch(error => {
                targetElement.innerHTML = '<option value="">-- Error loading classes --</option>';
                showToast('Failed to load classes', 'error');
                if (callback) callback();
            });
        }

        // Load subjects into multi-select dropdown
        function loadSubjects(classId, streamId) {
            if (!subjectDropdown) return;
            
            subjectDropdown.innerHTML = `
                <div class="multi-select-option" data-value="">
                    <div class="multi-select-checkbox"></div>
                    <span class="multi-select-label">-- Select Subject(s) --</span>
                </div>
            `;
            
            selectedSubjects = [];
            updateSubjectSelection();
            
            if (!classId) {
                if (subjectButton) subjectButton.disabled = true;
                return;
            }
            
            if (subjectButton) subjectButton.disabled = false;
            const streamParam = streamId === '' || streamId === null ? '' : streamId;
            
            fetch('lessons.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `action=get_subjects_by_class_stream&class_id=${classId}&stream_id=${streamParam}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success && data.subjects && data.subjects.length > 0) {
                    data.subjects.forEach(subject => {
                        const option = document.createElement('div');
                        option.className = 'multi-select-option';
                        option.setAttribute('data-value', subject.id);
                        option.innerHTML = `
                            <div class="multi-select-checkbox"></div>
                            <span class="multi-select-label">${escapeHtml(subject.subject_name)}</span>
                        `;
                        subjectDropdown.appendChild(option);
                    });
                } else if (data.success && (!data.subjects || data.subjects.length === 0)) {
                    const option = document.createElement('div');
                    option.className = 'multi-select-option';
                    option.setAttribute('data-value', '');
                    option.innerHTML = `
                        <div class="multi-select-checkbox"></div>
                        <span class="multi-select-label">No subjects found for this class/stream</span>
                    `;
                    option.style.opacity = '0.5';
                    option.style.cursor = 'not-allowed';
                    subjectDropdown.appendChild(option);
                    if (subjectButton) subjectButton.disabled = true;
                }
            })
            .catch(error => {
                const option = document.createElement('div');
                option.className = 'multi-select-option';
                option.setAttribute('data-value', '');
                option.innerHTML = `
                    <div class="multi-select-checkbox"></div>
                    <span class="multi-select-label">Error loading subjects</span>
                `;
                option.style.opacity = '0.5';
                option.style.cursor = 'not-allowed';
                subjectDropdown.appendChild(option);
                if (subjectButton) subjectButton.disabled = true;
            });
        }

        // Modal Functions
        function openAddLessonModal() {
            if (!checkPermission('canCreate')) return;
            
            document.getElementById('modalTitle').textContent = 'Assign Lesson';
            saveBtnText.textContent = 'Assign Lesson';
            
            lessonForm.reset();
            document.getElementById('lessonId').value = '';
            editingLessonId = null;
            
            if (streamSelect) {
                streamSelect.innerHTML = '<option value="">-- Select Stream (Optional) --</option>';
                streamSelect.disabled = true;
            }
            
            selectedSubjects = [];
            updateSubjectSelection();
            
            if (studentCount) {
                studentCount.innerHTML = '<i class="fas fa-users"></i><span>Select class and stream (optional) to see student count</span>';
            }
            
            if (assignAllCheckbox) {
                assignAllCheckbox.disabled = true;
                assignAllCheckbox.checked = false;
            }
            
            const studentSelectionInfo = document.getElementById('studentSelectionInfo');
            if (studentSelectionInfo) studentSelectionInfo.style.display = 'none';
            
            if (saveLessonBtn) saveLessonBtn.disabled = false;
            
            loadClasses(currentAcademicLevel, classSelect, null, function() {
                classSelect.disabled = false;
            });
            
            lessonModal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function editLesson(lessonId) {
            if (!checkPermission('canEdit')) return;
            
            editingLessonId = lessonId;
            
            showLoading(saveLessonBtn, 'Loading...');
            
            fetch('lessons.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `action=get_lesson&lesson_id=${lessonId}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const lesson = data.lesson;
                    
                    document.getElementById('modalTitle').textContent = 'Edit Lesson';
                    saveBtnText.textContent = 'Update Lesson';
                    document.getElementById('lessonId').value = lesson.id;
                    
                    loadClasses(currentAcademicLevel, classSelect, lesson.class_id, function() {
                        if (teacherSelect) teacherSelect.value = lesson.teacher_id;
                        loadStreams(lesson.class_id, lesson.stream_id);
                        
                        selectedSubjects = [lesson.subject_id.toString()];
                        
                        if (assignAllCheckbox && PERMISSIONS.canAssignStudents) {
                            const hasAssignments = lesson.assigned_students && lesson.assigned_students.length > 0;
                            assignAllCheckbox.checked = hasAssignments;
                        }
                        
                        setTimeout(() => {
                            loadSubjects(lesson.class_id, lesson.stream_id || '');
                            updateSubjectSelection();
                            updateStudentCount(lesson.class_id, lesson.stream_id || '');
                        }, 500);
                        
                        hideLoading(saveLessonBtn);
                    });
                    
                    lessonModal.classList.add('active');
                    document.body.style.overflow = 'hidden';
                } else {
                    showToast('Error', data.message, 'error');
                    hideLoading(saveLessonBtn);
                }
            })
            .catch(error => {
                showToast('Error', 'Failed to load lesson data', 'error');
                hideLoading(saveLessonBtn);
            });
        }

        function showDeleteModal(lessonId) {
            if (!checkPermission('canDelete')) return;
            
            lessonToDeleteId = lessonId;
            deleteModal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModals() {
            lessonModal.classList.remove('active');
            deleteModal.classList.remove('active');
            if (subjectButton) subjectButton.classList.remove('open');
            if (subjectDropdown) subjectDropdown.classList.remove('show');
            document.body.style.overflow = '';
        }

        // Form Handling Functions
        function handleClassChange() {
            const classId = classSelect.value;
            
            if (streamSelect) {
                streamSelect.innerHTML = '<option value="">-- Select Stream (Optional) --</option>';
                streamSelect.disabled = !classId;
            }
            
            selectedSubjects = [];
            updateSubjectSelection();
            
            if (subjectDropdown) {
                subjectDropdown.innerHTML = `
                    <div class="multi-select-option" data-value="">
                        <div class="multi-select-checkbox"></div>
                        <span class="multi-select-label">-- Select Subject(s) --</span>
                    </div>
                `;
            }
            
            if (assignAllCheckbox && PERMISSIONS.canAssignStudents) {
                assignAllCheckbox.disabled = !classId;
                assignAllCheckbox.checked = false;
            }
            
            if (saveLessonBtn) saveLessonBtn.disabled = !classId;
            
            if (classId) {
                loadStreams(classId);
                loadSubjects(classId, '');
                updateStudentCount(classId, '');
                const studentSelectionInfo = document.getElementById('studentSelectionInfo');
                if (studentSelectionInfo && PERMISSIONS.canAssignStudents) studentSelectionInfo.style.display = 'flex';
            } else {
                if (studentCount) {
                    studentCount.innerHTML = '<i class="fas fa-users"></i><span>Select class and stream (optional) to see student count</span>';
                }
                const studentSelectionInfo = document.getElementById('studentSelectionInfo');
                if (studentSelectionInfo) studentSelectionInfo.style.display = 'none';
            }
        }

        function handleStreamChange() {
            const classId = classSelect.value;
            const streamId = streamSelect.value || '';
            
            if (classId) {
                loadSubjects(classId, streamId);
                updateStudentCount(classId, streamId);
                if (assignAllCheckbox) assignAllCheckbox.checked = false;
            } else {
                if (studentCount) {
                    studentCount.innerHTML = '<i class="fas fa-users"></i><span>Select class and stream (optional) to see student count</span>';
                }
            }
        }

        function loadStreams(classId, selectedStreamId = null) {
            if (!streamSelect || !classId) return;
            
            streamSelect.innerHTML = '<option value="">-- Select Stream (Optional) --</option>';
            streamSelect.disabled = false;
            
            fetch('lessons.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `action=get_streams_by_class&class_id=${classId}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (data.streams && data.streams.length > 0) {
                        data.streams.forEach(stream => {
                            const option = document.createElement('option');
                            option.value = stream.id;
                            option.textContent = stream.stream_name;
                            if (selectedStreamId && stream.id == selectedStreamId) {
                                option.selected = true;
                            }
                            streamSelect.appendChild(option);
                        });
                    } else {
                        const option = document.createElement('option');
                        option.value = '';
                        option.textContent = 'No streams available';
                        option.disabled = true;
                        streamSelect.appendChild(option);
                    }
                } else {
                    const option = document.createElement('option');
                    option.value = '';
                    option.textContent = 'Error loading streams';
                    option.disabled = true;
                    streamSelect.appendChild(option);
                }
            })
            .catch(error => {
                const option = document.createElement('option');
                option.value = '';
                option.textContent = 'Error loading streams';
                option.disabled = true;
                streamSelect.appendChild(option);
            });
        }

        function updateStudentCount(classId, streamId) {
            if (!studentCount || !classId) {
                if (studentCount) {
                    studentCount.innerHTML = '<i class="fas fa-users"></i><span>Select class and stream (optional) to see student count</span>';
                }
                if (assignAllCheckbox) assignAllCheckbox.disabled = true;
                return;
            }
            
            studentCount.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>Loading student count...</span>';
            
            fetch('lessons.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `action=get_students_count_by_class&class_id=${classId}&stream_id=${streamId}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const studentCountText = `Total students in this class${streamId ? '/stream' : ''}: ${data.student_count}`;
                    studentCount.innerHTML = `<i class="fas fa-users"></i><span>${studentCountText}</span>`;
                    
                    if (assignAllCheckbox && PERMISSIONS.canAssignStudents) {
                        assignAllCheckbox.disabled = data.student_count === 0;
                        
                        if (data.student_count === 0) {
                            assignAllCheckbox.checked = false;
                            showToast('No students found in this class/stream. The "Assign all students" option is disabled.', 'warning');
                        }
                    }
                } else {
                    studentCount.innerHTML = '<i class="fas fa-exclamation-circle"></i><span>Error loading student count</span>';
                    if (assignAllCheckbox) assignAllCheckbox.disabled = true;
                }
            })
            .catch(error => {
                studentCount.innerHTML = '<i class="fas fa-exclamation-circle"></i><span>Error loading student count</span>';
                if (assignAllCheckbox) assignAllCheckbox.disabled = true;
            });
        }

        // Form Validation and Submission
        function validateLessonForm() {
            const classId = classSelect.value;
            const teacherId = teacherSelect.value;
            
            if (!classId) {
                showToast('Warning', 'Please select a class', 'warning');
                return false;
            }
            
            if (!teacherId) {
                showToast('Warning', 'Please select a teacher', 'warning');
                return false;
            }
            
            if (selectedSubjects.length === 0) {
                showToast('Warning', 'Please select at least one subject', 'warning');
                return false;
            }
            
            if (assignAllCheckbox && assignAllCheckbox.checked && assignAllCheckbox.disabled) {
                showToast('Warning', 'Cannot assign all students: No students found in this class/stream', 'warning');
                return false;
            }
            
            return true;
        }

        function saveLesson() {
            if (isSubmitting) return;
            
            const isEdit = editingLessonId !== null;
            if (isEdit && !checkPermission('canEdit')) return;
            if (!isEdit && !checkPermission('canCreate')) return;
            
            if (!validateLessonForm()) return;
            
            const formData = new FormData(lessonForm);
            const action = isEdit ? 'update_lesson' : 'add_lesson';
            
            formData.append('action', action);
            
            const assignAllStudents = assignAllCheckbox && assignAllCheckbox.checked ? '1' : '0';
            formData.append('assign_all_students', assignAllStudents);
            
            if (isEdit) {
                formData.append('subject_id', selectedSubjects[0]);
            } else {
                formData.append('subject_ids', selectedSubjects.join(','));
            }
            
            showLoading(saveLessonBtn, isEdit ? 'Updating...' : 'Saving...');
            isSubmitting = true;
            
            fetch('lessons.php', {
                method: 'POST',
                body: new URLSearchParams(formData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('Success', data.message, 'success');
                    closeModals();
                    loadLessonsAjax();
                    updateStats();
                } else {
                    showToast('Error', data.message, 'error');
                }
            })
            .catch(error => {
                showToast('Error', 'Failed to save lesson', 'error');
            })
            .finally(() => {
                isSubmitting = false;
                hideLoading(saveLessonBtn);
            });
        }

        // Delete Lesson
        function confirmDelete() {
            if (!checkPermission('canDelete')) return;
            if (isSubmitting) return;
            
            showLoading(confirmDeleteBtn, 'Deleting...');
            isSubmitting = true;
            
            fetch('lessons.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `action=delete_lesson&lesson_id=${lessonToDeleteId}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('Success', data.message, 'success');
                    closeModals();
                    loadLessonsAjax();
                    updateStats();
                } else {
                    showToast('Error', data.message, 'error');
                }
            })
            .catch(error => {
                showToast('Error', 'Failed to delete lesson', 'error');
            })
            .finally(() => {
                isSubmitting = false;
                hideLoading(confirmDeleteBtn);
            });
        }

        // AJAX Functions
        function applyFiltersAjax() {
            const classId = classFilter.value;
            currentPage = 1;
            loadLessonsAjax(classId);
        }

        function changePage(page) {
            if (page < 1) return;
            
            const classId = classFilter ? classFilter.value : '';
            currentPage = page;
            loadLessonsAjax(classId, page);
        }

        function loadLessonsAjax(classId = '', page = 1) {
            if (!lessonsTableBody) return;
            
            lessonsTableBody.innerHTML = `
                <tr>
                    <td colspan="6">
                        <div class="loading-state">
                            <div class="modern-spinner">
                                <div class="spinner-container">
                                    <div class="spinner-ring"></div>
                                    <div class="spinner-ring"></div>
                                    <div class="spinner-ring"></div>
                                    <div class="spinner-center">
                                        <i class="fas fa-book"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="loading-content">
                                <h3 class="loading-title">Loading Lessons</h3>
                                <p class="loading-text">Please wait while we fetch lesson information...</p>
                            </div>
                        </div>
                    </td>
                </tr>
            `;
            
            const formData = new FormData();
            formData.append('action', 'get_lessons_ajax');
            formData.append('page', page);
            if (classId) {
                formData.append('class_filter', classId);
            }
            
            fetch('lessons.php', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    lessonsTableBody.innerHTML = data.html;
                    updateURL(classId, page);
                } else {
                    showToast('Error', 'Failed to load lessons', 'error');
                }
            })
            .catch(error => {
                showToast('Error', 'Failed to load lessons', 'error');
            });
        }

        function updateURL(classId, page) {
            let url = `lessons.php?page=${page}`;
            if (classId) url += `&class_filter=${classId}`;
            window.history.pushState({ class_filter: classId, page: page }, '', url);
        }

        // Tab Functions
        function switchTab(tabId) {
            tabButtons.forEach(button => {
                button.classList.toggle('active', button.getAttribute('data-tab') === tabId);
            });
            
            tabContents.forEach(content => {
                content.classList.toggle('active', content.id === tabId);
            });
            
            if (tabId === 'students-tab' && studentClassFilter && studentClassFilter.value) {
                loadStudentAssignments();
            }
        }

        // Student Assignment Functions
        function handleStudentClassChange() {
            const classId = studentClassFilter.value;
            
            studentStreamFilter.innerHTML = '<option value="">Select Stream</option>';
            studentStreamFilter.disabled = true;
            
            if (classId) {
                fetch('lessons.php', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `action=get_streams_by_class&class_id=${classId}`
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.streams.length > 0) {
                        studentStreamFilter.disabled = false;
                        data.streams.forEach(stream => {
                            const option = document.createElement('option');
                            option.value = stream.id;
                            option.textContent = stream.stream_name;
                            studentStreamFilter.appendChild(option);
                        });
                    }
                    loadStudentAssignments();
                })
                .catch(error => {
                    showToast('Error', 'Failed to load streams', 'error');
                });
            } else {
                clearStudentTable();
            }
        }

        function loadStudentAssignments() {
            const classId = studentClassFilter.value;
            const streamId = studentStreamFilter ? studentStreamFilter.value || '' : '';
            
            if (!classId) {
                clearStudentTable();
                return;
            }
            
            studentsTableBody.innerHTML = `
                <tr>
                    <td colspan="2">
                        <div class="loading-state">
                            <div class="spinner" style="margin: 0 auto;"></div>
                            <p>Loading student assignments...</p>
                        </div>
                    </td>
                </tr>
            `;
            
            fetch('lessons.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `action=get_student_subject_assignments&class_id=${classId}&stream_id=${streamId}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    renderStudentAssignments(data.students, data.subjects, data.student_assignments);
                    currentStudentAssignments = data.student_assignments;
                } else {
                    showToast('Error', 'Failed to load student assignments', 'error');
                    clearStudentTable();
                }
            })
            .catch(error => {
                showToast('Error', 'Failed to load student assignments', 'error');
                clearStudentTable();
            });
        }

function renderStudentAssignments(students, subjects, studentAssignments) {
    const studentsTableHead = document.getElementById('studentsTableHead');
    const studentsTableBody = document.getElementById('studentsTableBody');
    
    if (!studentsTableHead || !studentsTableBody) return;
    
    studentsTableHead.innerHTML = '';
    studentsTableBody.innerHTML = '';
    
    if (!students || students.length === 0 || !subjects || subjects.length === 0) {
        studentsTableBody.innerHTML = `
            <tr>
                <td colspan="${2 + (subjects ? subjects.length : 0)}">
                    <div class="empty-state-students">
                        <i class="fas fa-info-circle"></i>
                        <h3>No Data Available</h3>
                        <p>No students or subjects found for this class/stream</p>
                    </div>
                 </td>
            </tr>
        `;
        return;
    }
    
    const headerRow = document.createElement('tr');
    headerRow.innerHTML = `
        <th><i class="fas fa-user"></i> Student Name</th>
        <th><i class="fas fa-id-card"></i> Admission No</th>
    `;
    
    subjects.forEach(subject => {
        const subjectHeader = document.createElement('th');
        subjectHeader.className = 'subject-column';
        subjectHeader.textContent = subject.subject_name;
        subjectHeader.setAttribute('data-subject-id', subject.id);
        subjectHeader.setAttribute('data-subject', subject.subject_name);
        headerRow.appendChild(subjectHeader);
    });
    
    studentsTableHead.appendChild(headerRow);
    
    students.forEach(student => {
        const row = document.createElement('tr');
        row.setAttribute('data-student-id', student.id);
        
        const fullName = [student.FirstName, student.SecondName, student.LastName]
            .filter(name => name && name.trim() !== '')
            .join(' ');
        
        let rowHTML = `
            <td class="student-name-cell">
                <i class="fas fa-user-graduate" style="margin-right: 0.5rem; color: var(--primary-blue);"></i>
                ${escapeHtml(fullName)}
            </td>
            <td class="admission-cell">
                <i class="fas fa-id-card" style="margin-right: 0.5rem; color: var(--text-light);"></i>
                ${escapeHtml(student.AdmNo || 'N/A')}
            </td>
        `;
        
        subjects.forEach(subject => {
            const isAssigned = studentAssignments[student.id] && 
                              studentAssignments[student.id].includes(parseInt(subject.id));
            const canEdit = PERMISSIONS.canAssignStudents || PERMISSIONS.canEdit || PERMISSIONS.isSuperAdmin;
            
            rowHTML += `
                <td class="subject-cell">
                    <input type="checkbox" 
                           class="student-checkbox" 
                           data-student-id="${student.id}" 
                           data-subject-id="${subject.id}"
                           ${isAssigned ? 'checked' : ''}
                           ${!canEdit ? 'disabled' : ''}
                           onchange="toggleStudentAssignment(this, ${student.id}, ${subject.id})">
                </td>
            `;
        });
        
        row.innerHTML = rowHTML;
        studentsTableBody.appendChild(row);
    });
}

        function clearStudentTable() {
            studentsTableHead.innerHTML = `
                <tr>
                    <th>Student Name</th>
                    <th>Admission No</th>
                </tr>
            `;
            studentsTableBody.innerHTML = `
                <tr>
                    <td colspan="2">
                        <div class="empty-state">
                            <i class="fas fa-users"></i>
                            <h3>No Data to Display</h3>
                            <p>Please select a class to view student assignments</p>
                        </div>
                    </td>
                </tr>
            `;
        }

        async function toggleStudentAssignment(checkbox, studentId, subjectId) {
            if (!PERMISSIONS.canAssignStudents && !PERMISSIONS.canEdit && !PERMISSIONS.isSuperAdmin) {
                showToast('Access Denied', 'You do not have permission to assign students', 'error');
                checkbox.checked = !checkbox.checked;
                return;
            }
            
            if (isSubmitting) return;
            
            const isChecked = checkbox.checked;
            
            checkbox.classList.add('loading');
            checkbox.disabled = true;
            isSubmitting = true;
            
            try {
                const response = await fetch('lessons.php', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `action=update_student_assignment&student_id=${studentId}&subject_id=${subjectId}&assign=${isChecked}`
                });
                
                const data = await response.json();
                
                if (data.success) {
                    showToast('Success', data.message, 'success');
                    updateStats();
                    
                    if (isChecked) {
                        if (!currentStudentAssignments[studentId]) {
                            currentStudentAssignments[studentId] = [];
                        }
                        if (!currentStudentAssignments[studentId].includes(subjectId)) {
                            currentStudentAssignments[studentId].push(subjectId);
                        }
                    } else {
                        if (currentStudentAssignments[studentId]) {
                            const index = currentStudentAssignments[studentId].indexOf(subjectId);
                            if (index > -1) {
                                currentStudentAssignments[studentId].splice(index, 1);
                            }
                        }
                    }
                } else {
                    checkbox.checked = !isChecked;
                    showToast('Error', data.message, 'error');
                }
            } catch (error) {
                checkbox.checked = !isChecked;
                showToast('Error', 'Failed to update student assignment', 'error');
            } finally {
                isSubmitting = false;
                checkbox.classList.remove('loading');
                checkbox.disabled = false;
            }
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize multi-select
            initMultiSelect();
            
            // Load initial data
            loadClasses(currentAcademicLevel, classFilter, <?php echo isset($class_filter) && $class_filter !== '' ? $class_filter : 'null'; ?>, function() {
                loadLessonsAjax();
            });
            if (studentClassFilter) loadClasses(currentAcademicLevel, studentClassFilter);
            if (classSelect) loadClasses(currentAcademicLevel, classSelect);
            
            // Event Listeners
            if (addLessonBtn) addLessonBtn.addEventListener('click', openAddLessonModal);
            if (closeModalBtn) closeModalBtn.addEventListener('click', closeModals);
            if (cancelBtn) cancelBtn.addEventListener('click', closeModals);
            if (lessonModal) {
                lessonModal.addEventListener('click', (e) => {
                    if (e.target === lessonModal) closeModals();
                });
            }
            
            if (confirmDeleteBtn) confirmDeleteBtn.addEventListener('click', confirmDelete);
            if (cancelDeleteBtn) cancelDeleteBtn.addEventListener('click', closeModals);
            if (closeDeleteModal) closeDeleteModal.addEventListener('click', closeModals);
            if (deleteModal) {
                deleteModal.addEventListener('click', (e) => {
                    if (e.target === deleteModal) closeModals();
                });
            }
            
            if (lessonForm) {
                lessonForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    saveLesson();
                });
            }
            
            // Academic level change
            if (academicLevelFilter) {
                academicLevelFilter.addEventListener('change', function() {
                    currentAcademicLevel = this.value;
                    loadClasses(currentAcademicLevel, classFilter, null, function() {
                        if (classFilter) classFilter.value = '';
                        loadLessonsAjax();
                    });
                    
                    if (studentClassFilter) {
                        loadClasses(currentAcademicLevel, studentClassFilter);
                    }
                    
                    if (classSelect) {
                        loadClasses(currentAcademicLevel, classSelect);
                    }
                });
            }
            
            // Tab events
            tabButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const tabId = this.getAttribute('data-tab');
                    switchTab(tabId);
                });
            });
            
            // Filter events
            if (classFilter) classFilter.addEventListener('change', applyFiltersAjax);
            if (studentClassFilter) studentClassFilter.addEventListener('change', handleStudentClassChange);
            if (studentStreamFilter) studentStreamFilter.addEventListener('change', loadStudentAssignments);
            
            // Form events
            if (classSelect) classSelect.addEventListener('change', handleClassChange);
            if (streamSelect) streamSelect.addEventListener('change', handleStreamChange);
            
            // Search
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const searchTerm = this.value.toLowerCase();
                    const rows = lessonsTableBody.querySelectorAll('tr[data-lesson-id]');
                    
                    rows.forEach(row => {
                        const text = row.textContent.toLowerCase();
                        row.style.display = text.includes(searchTerm) ? '' : 'none';
                    });
                });
            }
        });

        // Make functions available globally
        window.openAddLessonModal = openAddLessonModal;
        window.editLesson = editLesson;
        window.showDeleteModal = showDeleteModal;
        window.changePage = changePage;
        window.toggleStudentAssignment = toggleStudentAssignment;
    </script>
</body>

</body>
</html>
