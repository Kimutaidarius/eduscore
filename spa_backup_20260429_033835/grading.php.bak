                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" id="cancelBtn" <?php echo (!$canCreate && !$canEdit) ? 'disabled' : ''; ?>>
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary" id="saveGradeBtn" <?php echo (!$canCreate && !$canEdit) ? 'disabled' : ''; ?>>
                        <i class="fas fa-save"></i>
                        <span id="saveBtnText">Save Custom Grade</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
    

    <?php if ($canDelete): ?>
    <!-- Delete Confirmation Modal -->
    <div class="modal-overlay" id="deleteModal">
        <div class="modal delete-modal">
            <div class="modal-header">
                <h3 class="modal-title">
                    <i class="fas fa-exclamation-triangle"></i>
                    Delete Custom Grade
                </h3>
                <button class="close-modal" id="closeDeleteModal">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this custom grade?</p>
                <div class="delete-warning">
                    <i class="fas fa-info-circle"></i>
                    After deletion, the system will use default CBE grades for this class/stream.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="cancelDeleteBtn">
                    Cancel
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fas fa-trash"></i> Delete Custom Grade
                </button>
            </div>
        </div>
    </div>
    

    <!-- View Grades Modal -->
    <div class="modal-overlay" id="viewModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">
                    <i class="fas fa-eye"></i>
                    View Grades for <span id="viewClassTitle"></span>
                </h3>
                <button class="close-modal" id="closeViewModal">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Default CBE Grades (System Default)</label>
                    <div id="defaultGradesView" class="default-grades-grid" style="margin-top: 1rem;">
                        <!-- Default grades will be shown here -->
                    </div>
                </div>
                
                <div class="form-group" style="margin-top: 2rem;">
                    <label class="form-label">Custom Grades (Override)</label>
                    <div id="customGradesView" style="margin-top: 1rem;">
                        <!-- Custom grades will be shown here -->
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="closeViewBtn">
                    Close
                </button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- JavaScript -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Global variables
    let editingGradeId = null;
    let gradeToDeleteId = null;
    let isSubmitting = false;

    // Permissions from PHP
    const PERMISSIONS = {
        canCreate: <?php echo $canCreate ? 'true' : 'false'; ?>,
        canEdit: <?php echo $canEdit ? 'true' : 'false'; ?>,
        canDelete: <?php echo $canDelete ? 'true' : 'false'; ?>,
        canViewAll: <?php echo $canViewAll ? 'true' : 'false'; ?>,
        canUseDefaults: <?php echo $canUseDefaults ? 'true' : 'false'; ?>,
        isSuperAdmin: <?php echo $isSuperAdmin ? 'true' : 'false'; ?>
    };

    // DOM Elements
    const addGradeBtn = document.getElementById('addGradeBtn');
    const viewGradesBtn = document.getElementById('viewGradesBtn');
    const loadGradesBtn = document.getElementById('loadGradesBtn');
    const useDefaultsBtn = document.getElementById('useDefaultsBtn');
    const deleteCustomBtn = document.getElementById('deleteCustomBtn');
    const gradeModal = document.getElementById('gradeModal');
    const deleteModal = document.getElementById('deleteModal');
    const viewModal = document.getElementById('viewModal');
    const closeModalBtn = document.getElementById('closeModal');
    const cancelBtn = document.getElementById('cancelBtn');
    const saveGradeBtn = document.getElementById('saveGradeBtn');
    const saveBtnText = document.getElementById('saveBtnText');
    const searchInput = document.getElementById('searchInput');
    const gradesTableBody = document.getElementById('gradesTableBody');
    const toastContainer = document.getElementById('toastContainer');
    const selectClass = document.getElementById('selectClass');
    const selectStream = document.getElementById('selectStream');
    const gradeForm = document.getElementById('gradeForm');
    const closeDeleteModal = document.getElementById('closeDeleteModal');
    const cancelDeleteBtn = document.getElementById('cancelDeleteBtn');
    const confirmDeleteBtn = document.getElementById('confirmDeleteBtn');
    const closeViewModal = document.getElementById('closeViewModal');
    const closeViewBtn = document.getElementById('closeViewBtn');
    const defaultGradesView = document.getElementById('defaultGradesView');
    const customGradesView = document.getElementById('customGradesView');
    const viewClassTitle = document.getElementById('viewClassTitle');

    // Default grades (from PHP) - with proper error handling
    let defaultGrades = [];
    try {
        // Use JSON.parse with proper escaping
        const defaultGradesJson = '<?php 
            echo addslashes(json_encode($default_grades, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP));
        ?>';
        defaultGrades = JSON.parse(defaultGradesJson);
    } catch (e) {
        console.error('Error parsing default grades:', e);
        // Fallback to hardcoded defaults
        defaultGrades = [
            {lower_limit: 0, upper_limit: 24, grade: 'BE', points: 1.00, remarks: 'Below Expectation'},
            {lower_limit: 25, upper_limit: 49, grade: 'AE', points: 2.00, remarks: 'Approaching Expectation'},
            {lower_limit: 50, upper_limit: 74, grade: 'ME', points: 3.00, remarks: 'Meet Expectation'},
            {lower_limit: 75, upper_limit: 100, grade: 'EE', points: 4.00, remarks: 'Exceeding Expectation'}
        ];
    }

    // Toast Notification Function
    function showToast(title, message, type = 'success') {
        const toast = document.createElement('div');
        toast.className = `toast ${type}`;
        
        let icon = 'check';
        if (type === 'error') icon = 'exclamation-triangle';
        if (type === 'warning') icon = 'exclamation-circle';
        if (type === 'info') icon = 'info-circle';
        
        toast.innerHTML = `
            <div class="toast-icon">
                <i class="fas fa-${icon}"></i>
            </div>
            <div class="toast-content">
                <div class="toast-title">${title}</div>
                <div class="toast-message">${message}</div>
            </div>
        `;
        
        toastContainer.appendChild(toast);
        
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(100%)';
            toast.style.transition = 'all 0.3s ease';
            setTimeout(() => toast.remove(), 300);
        }, 5000);
    }

    // Check permission function
    function checkPermission(action) {
        if (!PERMISSIONS[action] && !PERMISSIONS.isSuperAdmin) {
            showToast('Access Denied', 'You do not have permission to perform this action', 'error');
            return false;
        }
        return true;
    }

    // Loading States
    function showLoading(button, text) {
        const originalHTML = button.innerHTML;
        button.dataset.originalHTML = originalHTML;
        button.innerHTML = `
            <div style="display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; border-top-color: white; animation: spin 1s ease-in-out infinite; margin-right: 8px;"></div>
            ${text}
        `;
        button.disabled = true;
    }
    
    function hideLoading(button) {
        if (button.dataset.originalHTML) {
            button.innerHTML = button.dataset.originalHTML;
        }
        button.disabled = false;
    }

    // Add CSS for spinner animation
    const style = document.createElement('style');
    style.textContent = `
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    `;
    document.head.appendChild(style);

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // Load streams for a class
    function loadStreams(classId, targetElement, selectedStreamId = null) {
        if (!targetElement || !classId) {
            if (targetElement) {
                targetElement.innerHTML = '<option value="">-- Select Class First --</option>';
                targetElement.disabled = true;
            }
            return;
        }
        
        targetElement.innerHTML = '<option value="">-- Loading streams... --</option>';
        targetElement.disabled = false;
        
        fetch('grading.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `action=get_streams_by_class&class_id=${classId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success && data.streams && data.streams.length > 0) {
                let options = '<option value="">-- All Streams --</option>';
                data.streams.forEach(stream => {
                    const selected = selectedStreamId && stream.id == selectedStreamId ? 'selected' : '';
                    options += `<option value="${stream.id}" ${selected}>${stream.stream_name}</option>`;
                });
                targetElement.innerHTML = options;
            } else {
                targetElement.innerHTML = '<option value="">-- No streams available --</option>';
            }
        })
        .catch(error => {
            targetElement.innerHTML = '<option value="">-- Error loading streams --</option>';
            showToast('Error', 'Failed to load streams', 'error');
        });
    }

    // Check for custom grades
    function checkCustomGrades() {
        const classId = selectClass.value;
        const streamId = selectStream.value || '';
        
        if (!classId) {
            showToast('Warning', 'Please select a class first', 'warning');
            return;
        }
        
        showLoading(loadGradesBtn, 'Checking...');
        
        fetch('grading.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `action=get_grades_by_class_stream&class_id=${classId}&stream_id=${streamId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                if (data.has_custom_grades) {
                    showToast('Info', 'This class has custom grades. System will use these instead of defaults.', 'info');
                    renderCustomGradesTable(data.custom_grades);
                } else {
                    showToast('Info', 'No custom grades found. System is using default CBE grades.', 'info');
                }
            } else {
                showToast('Error', data.message, 'error');
            }
        })
        .catch(error => {
            showToast('Error', 'Failed to check grades', 'error');
        })
        .finally(() => {
            hideLoading(loadGradesBtn);
        });
    }

    // Render custom grades table
    function renderCustomGradesTable(grades) {
        if (!grades || grades.length === 0) {
            gradesTableBody.innerHTML = `
                <tr>
                    <td colspan="8">
                        <div class="empty-state">
                            <i class="fas fa-chart-bar"></i>
                            <h3>No Custom Grades Found</h3>
                            <p>All classes are using the default CBE grading scale.</p>
                            <p style="font-size: 0.9rem; color: var(--text-light); margin-top: 0.5rem;">
                                <i class="fas fa-info-circle"></i> The system automatically uses default grades (BE, AE, ME, EE)
                            </p>
                            ${PERMISSIONS.canCreate ? `
                                <button class="btn btn-primary" onclick="openAddGradeModal()" style="margin-top: 1.5rem;">
                                    <i class="fas fa-plus"></i> Add Custom Grade Scale
                                </button>
                            ` : ''}
                        </div>
                    </td>
                </tr>
            `;
            return;
        }
        
        let html = '';
        grades.forEach(grade => {
            const gradeClass = `grade-${grade.grade}`;
            
            html += `
                <tr data-grade-id="${grade.id}">
                    <td>${escapeHtml(grade.class_level || 'N/A')}</td>
                    <td>${escapeHtml(grade.stream_name || 'All Streams')}</td>
                    <td><strong>${grade.lower_limit}%</strong></td>
                    <td><strong>${grade.upper_limit}%</strong></td>
                    <td>
                        <span class="grade-badge ${gradeClass}">
                            ${grade.grade}
                        </span>
                    </td>
                    <td>
                        <div class="rubric-points">
                            <div class="points-circle">${grade.points}</div>
                            <span>points</span>
                        </div>
                    </td>
                    <td>${escapeHtml(grade.remarks || '')}</td>
                    <td>
                        <div class="actions">
                            ${PERMISSIONS.canEdit ? `
                                <button class="action-btn-small edit-btn" onclick="editGrade(${grade.id})">
                                    <i class="fas fa-edit"></i>
                                </button>
                            ` : ''}
                            ${PERMISSIONS.canDelete ? `
                                <button class="action-btn-small delete-btn" onclick="showDeleteModal(${grade.id})">
                                    <i class="fas fa-trash"></i>
                                </button>
                            ` : ''}
                        </div>
                    </td>
                </tr>
            `;
        });
        
        gradesTableBody.innerHTML = html;
    }

    // View grades for selected class
    function viewGrades() {
        const classId = selectClass.value;
        const streamId = selectStream.value || '';
        
        if (!classId) {
            showToast('Warning', 'Please select a class first', 'warning');
            return;
        }
        
        // Get class name for title
        const className = selectClass.options[selectClass.selectedIndex].text;
        const streamName = streamId ? selectStream.options[selectStream.selectedIndex].text : 'All Streams';
        
        viewClassTitle.textContent = `${className} (${streamName})`;
        
        // Show default grades
        let defaultHtml = '';
        defaultGrades.forEach(grade => {
            const gradeClass = `grade-${grade.grade}`;
            defaultHtml += `
                <div class="default-grade-item">
                    <div class="default-grade-range">${grade.lower_limit}-${grade.upper_limit}%</div>
                    <span class="grade-badge ${gradeClass}">${grade.grade}</span>
                    <div class="default-grade-points">${grade.points} pts</div>
                    <div class="default-grade-remarks">${grade.remarks}</div>
                </div>
            `;
        });
        defaultGradesView.innerHTML = defaultHtml;
        
        // Load custom grades
        customGradesView.innerHTML = '<p style="color: var(--text-light);"><i class="fas fa-spinner fa-spin"></i> Loading custom grades...</p>';
        
        fetch('grading.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `action=get_grades_by_class_stream&class_id=${classId}&stream_id=${streamId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                if (data.has_custom_grades) {
                    let customHtml = '<div class="default-grades-grid">';
                    data.custom_grades.forEach(grade => {
                        const gradeClass = `grade-${grade.grade}`;
                        customHtml += `
                            <div class="default-grade-item" style="border-color: var(--primary-blue);">
                                <div class="default-grade-range">${grade.lower_limit}-${grade.upper_limit}%</div>
                                <span class="grade-badge ${gradeClass}">${grade.grade}</span>
                                <div class="default-grade-points">${grade.points} pts</div>
                                <div class="default-grade-remarks">${grade.remarks}</div>
                            </div>
                        `;
                    });
                    customHtml += '</div>';
                    customHtml += '<p style="margin-top: 1rem; font-size: 0.9rem; color: var(--primary-blue);"><i class="fas fa-info-circle"></i> Custom grades override default CBE grades</p>';
                    customGradesView.innerHTML = customHtml;
                } else {
                    customGradesView.innerHTML = '<p style="color: var(--text-light);"><i class="fas fa-info-circle"></i> No custom grades. System is using default CBE grades.</p>';
                }
            } else {
                customGradesView.innerHTML = '<p style="color: var(--error-red);"><i class="fas fa-exclamation-circle"></i> Failed to load custom grades</p>';
            }
        })
        .catch(error => {
            customGradesView.innerHTML = '<p style="color: var(--error-red);"><i class="fas fa-exclamation-circle"></i> Failed to load custom grades</p>';
        });
        
        viewModal.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    // Modal Functions
    function openAddGradeModal() {
        if (!checkPermission('canCreate')) return;
        
        document.getElementById('modalTitle').textContent = 'Add Custom Grade';
        saveBtnText.textContent = 'Save Custom Grade';
        
        gradeForm.reset();
        document.getElementById('gradeId').value = '';
        editingGradeId = null;
        
        // Reset the class select to default option
        document.getElementById('classSelectModal').selectedIndex = 0;
        
        if (document.getElementById('streamSelectModal')) {
            document.getElementById('streamSelectModal').innerHTML = '<option value="">-- Select Stream (Optional) --</option>';
        }
        
        gradeModal.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function editGrade(gradeId) {
        if (!checkPermission('canEdit')) return;
        
        editingGradeId = gradeId;
        
        showLoading(saveGradeBtn, 'Loading...');
        
        fetch('grading.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `action=get_grade&grade_id=${gradeId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const grade = data.grade;
                
                document.getElementById('modalTitle').textContent = 'Edit Custom Grade';
                saveBtnText.textContent = 'Update Custom Grade';
                document.getElementById('gradeId').value = grade.id;
                document.getElementById('classSelectModal').value = grade.class_id;
                document.getElementById('lowerLimit').value = grade.lower_limit;
                document.getElementById('upperLimit').value = grade.upper_limit;
                document.getElementById('grade').value = grade.grade;
                document.getElementById('points').value = grade.points;
                document.getElementById('remarks').value = grade.remarks;
                
                loadStreams(grade.class_id, document.getElementById('streamSelectModal'), grade.stream_id);
                
                hideLoading(saveGradeBtn);
                
                gradeModal.classList.add('active');
                document.body.style.overflow = 'hidden';
            } else {
                showToast('Error', data.message, 'error');
                hideLoading(saveGradeBtn);
            }
        })
        .catch(error => {
            showToast('Error', 'Failed to load grade data', 'error');
            hideLoading(saveGradeBtn);
        });
    }

    function showDeleteModal(gradeId) {
        if (!checkPermission('canDelete')) return;
        
        gradeToDeleteId = gradeId;
        deleteModal.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeModals() {
        gradeModal.classList.remove('active');
        deleteModal.classList.remove('active');
        viewModal.classList.remove('active');
        document.body.style.overflow = '';
    }

    // Form Validation
    function validateGradeForm() {
        const classId = document.getElementById('classSelectModal').value;
        const lowerLimit = parseInt(document.getElementById('lowerLimit').value);
        const upperLimit = parseInt(document.getElementById('upperLimit').value);
        const grade = document.getElementById('grade').value.trim();
        const points = parseFloat(document.getElementById('points').value);
        const remarks = document.getElementById('remarks').value.trim();
        
        if (!classId) {
            showToast('Warning', 'Please select a class', 'warning');
            return false;
        }
        
        if (isNaN(lowerLimit) || lowerLimit < 0 || lowerLimit > 100) {
            showToast('Warning', 'Lower limit must be a number between 0 and 100', 'warning');
            return false;
        }
        
        if (isNaN(upperLimit) || upperLimit < 0 || upperLimit > 100) {
            showToast('Warning', 'Upper limit must be a number between 0 and 100', 'warning');
            return false;
        }
        
        if (lowerLimit >= upperLimit) {
            showToast('Warning', 'Lower limit must be less than upper limit', 'warning');
            return false;
        }
        
        if (!grade) {
            showToast('Warning', 'Please enter a grade', 'warning');
            return false;
        }
        
        if (isNaN(points) || points < 0 || points > 4) {
            showToast('Warning', 'Points must be a number between 0 and 4', 'warning');
            return false;
        }
        
        if (!remarks) {
            showToast('Warning', 'Please enter remarks', 'warning');
            return false;
        }
        
        return true;
    }

    // Save custom grade
    function saveGrade() {
        if (isSubmitting) return;
        
        const isEdit = editingGradeId !== null;
        if (isEdit && !checkPermission('canEdit')) return;
        if (!isEdit && !checkPermission('canCreate')) return;
        
        if (!validateGradeForm()) return;
        
        const formData = new FormData(gradeForm);
        const action = isEdit ? 'update_grade' : 'add_grade';
        
        formData.append('action', action);
        
        showLoading(saveGradeBtn, isEdit ? 'Updating...' : 'Saving...');
        isSubmitting = true;
        
        fetch('grading.php', {
            method: 'POST',
            body: new URLSearchParams(formData)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast('Success', data.message, 'success');
                closeModals();
                // Refresh the page to show updated custom grades
                location.reload();
            } else {
                showToast('Error', data.message, 'error');
            }
        })
        .catch(error => {
            showToast('Error', 'Failed to save custom grade', 'error');
        })
        .finally(() => {
            isSubmitting = false;
            hideLoading(saveGradeBtn);
        });
    }

    // Delete custom grade
    function confirmDelete() {
        if (!checkPermission('canDelete')) return;
        if (isSubmitting) return;
        
        showLoading(confirmDeleteBtn, 'Deleting...');
        isSubmitting = true;
        
        fetch('grading.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `action=delete_grade&grade_id=${gradeToDeleteId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast('Success', data.message, 'success');
                closeModals();
                // Refresh the page to show updated custom grades
                location.reload();
            } else {
                showToast('Error', data.message, 'error');
            }
        })
        .catch(error => {
            showToast('Error', 'Failed to delete custom grade', 'error');
        })
        .finally(() => {
            isSubmitting = false;
            hideLoading(confirmDeleteBtn);
        });
    }

    // Use default CBE grades
    function useDefaultGrades() {
        if (!checkPermission('canCreate') && !checkPermission('canUseDefaults')) return;
        
        const classId = selectClass.value;
        const streamId = selectStream.value || '';
        
        if (!classId) {
            showToast('Warning', 'Please select a class first', 'warning');
            return;
        }
        
        if (!confirm('Save default CBE grades as custom grades for this class? This will override any existing custom grades.')) {
            return;
        }
        
        showLoading(useDefaultsBtn, 'Saving...');
        
        fetch('grading.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `action=save_default_grades&class_id=${classId}&stream_id=${streamId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast('Success', data.message, 'success');
                // Refresh the page to show updated custom grades
                location.reload();
            } else {
                showToast('Error', data.message, 'error');
            }
        })
        .catch(error => {
            showToast('Error', 'Failed to save default grades', 'error');
        })
        .finally(() => {
            hideLoading(useDefaultsBtn);
        });
    }

    // Delete all custom grades for class
    function deleteCustomGrades() {
        if (!checkPermission('canDelete')) return;
        
        const classId = selectClass.value;
        const streamId = selectStream.value || '';
        
        if (!classId) {
            showToast('Warning', 'Please select a class first', 'warning');
            return;
        }
        
        if (!confirm('Delete all custom grades for this class? The system will use default CBE grades.')) {
            return;
        }
        
        showLoading(deleteCustomBtn, 'Deleting...');
        
        fetch('grading.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `action=delete_custom_grades&class_id=${classId}&stream_id=${streamId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast('Success', data.message, 'success');
                // Refresh the page to show updated custom grades
                location.reload();
            } else {
                showToast('Error', data.message, 'error');
            }
        })
        .catch(error => {
            showToast('Error', 'Failed to delete custom grades', 'error');
        })
        .finally(() => {
            hideLoading(deleteCustomBtn);
        });
    }

    // Update stats
    function updateStats() {
        fetch('grading.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'action=get_custom_grades_count'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById('customGradesCount').textContent = data.total_custom_grades;
            }
        })
        .catch(error => {
            console.error('Failed to update stats:', error);
        });
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
        // Event Listeners
        if (addGradeBtn) addGradeBtn.addEventListener('click', openAddGradeModal);
        if (viewGradesBtn) viewGradesBtn.addEventListener('click', viewGrades);
        if (loadGradesBtn) loadGradesBtn.addEventListener('click', checkCustomGrades);
        if (useDefaultsBtn) useDefaultsBtn.addEventListener('click', useDefaultGrades);
        if (deleteCustomBtn) deleteCustomBtn.addEventListener('click', deleteCustomGrades);
        
        if (closeModalBtn) closeModalBtn.addEventListener('click', closeModals);
        if (cancelBtn) cancelBtn.addEventListener('click', closeModals);
        if (gradeModal) {
            gradeModal.addEventListener('click', (e) => {
                if (e.target === gradeModal) closeModals();
            });
        }
        
        if (confirmDeleteBtn) confirmDeleteBtn.addEventListener('click', confirmDelete);
        if (cancelDeleteBtn) cancelDeleteBtn.addEventListener('click', closeModals);
        if (closeDeleteModal) closeDeleteModal.addEventListener('click', closeModals);
        if (deleteModal) {
            deleteModal.addEventListener('click', (e) => {
                if (e.target === deleteModal) closeModals();
            });
        }
        
        if (closeViewModal) closeViewModal.addEventListener('click', closeModals);
        if (closeViewBtn) closeViewBtn.addEventListener('click', closeModals);
        if (viewModal) {
            viewModal.addEventListener('click', (e) => {
                if (e.target === viewModal) closeModals();
            });
        }
        
        if (gradeForm) {
            gradeForm.addEventListener('submit', function(e) {
                e.preventDefault();
                saveGrade();
            });
        }
        
        // Class change events
        selectClass.addEventListener('change', function() {
            const classId = this.value;
            if (classId) {
                loadStreams(classId, selectStream);
                selectStream.disabled = false;
            } else {
                selectStream.innerHTML = '<option value="">-- Select Class First --</option>';
                selectStream.disabled = true;
            }
        });
        
        // Search
        if (searchInput) {
            searchInput.addEventListener('input', function() {
                const searchTerm = this.value.toLowerCase();
                const rows = gradesTableBody.querySelectorAll('tr[data-grade-id]');
                
                rows.forEach(row => {
                    const text = row.textContent.toLowerCase();
                    row.style.display = text.includes(searchTerm) ? '' : 'none';
                });
            });
        }
        
        // Update stats periodically
        setInterval(updateStats, 30000); // Update every 30 seconds
    });

    // Make functions available globally
    window.openAddGradeModal = openAddGradeModal;
    window.editGrade = editGrade;
    window.showDeleteModal = showDeleteModal;
    window.viewGrades = viewGrades;
</script>
</body>

</body>
</html>
