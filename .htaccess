# =========================================================
# PRODUCTION .HTACCESS - EDUSCORE (FINAL - HARDENED & STABLE)
# =========================================================

Options -Indexes
ServerSignature Off
TraceEnable Off

RewriteEngine On
# RewriteBase / - REMOVED (not needed for root domain)

# =========================================================
# .well-known EXCEPTION (SSL, Apple Pay, security.txt)
# =========================================================
RewriteRule ^\.well-known/ - [L,NC]

# =========================================================
# FORCE HTTPS & CANONICAL DOMAIN (Fixed redirect chain)
# =========================================================
# Redirect WWW to non-WWW first
RewriteCond %{HTTP_HOST} ^www\.eduscore\.co\.ke [NC]
RewriteRule ^ https://eduscore.co.ke%{REQUEST_URI} [L,R=301]

# Force HTTPS (works behind Cloudflare/proxies)
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://eduscore.co.ke%{REQUEST_URI} [L,R=301]

# =========================================================
# BLOCK HTTP VERB ABUSE (TRACE, DELETE, TRACK, DEBUG)
# =========================================================
RewriteCond %{REQUEST_METHOD} ^(TRACE|DELETE|TRACK|DEBUG) [NC]
RewriteRule .* - [F,L]

# =========================================================
# SECURITY HEADERS (Cookie hardening removed - handled in PHP)
# =========================================================
<IfModule mod_headers.c>

    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always unset X-XSS-Protection
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    
    # Cache-Control for static assets
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|svg|webp|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # =====================================================
    # CONTENT SECURITY POLICY (TEST CAREFULLY)
    # Monitor browser console for violations
    # =====================================================
    Header always set Content-Security-Policy "
        default-src 'self';
        script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com;
        style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com;
        font-src 'self' https://fonts.gstatic.com data:;
        img-src 'self' data: https:;
        connect-src 'self' https:;
        object-src 'none';
        frame-ancestors 'self';
        base-uri 'self';
        form-action 'self';
    "

</IfModule>

# =========================================================
# X-ROBOTS-TAG FOR PROTECTED PAGES
# =========================================================
<FilesMatch "^(dashboard|login|register|reports|subscription|admin|students|teachers|scores|grading|exams|classes|subjects)\.php$">
    Header set X-Robots-Tag "noindex, nofollow"
</FilesMatch>

# =========================================================
# PROTECT SENSITIVE FILES (XML ALLOWED for sitemap)
# =========================================================
<FilesMatch "\.(yml|yaml|env|ini|log|sql|bak|backup|old|orig|save|swp|dist)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(composer\.(json|lock)|package\.json|webpack\.config|vite\.config|config|database|db|connection|settings)\.php$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# =========================================================
# API & AJAX EXCLUSIONS (MUST come before clean URL rules)
# =========================================================
RewriteRule ^api/ - [L,NC]
RewriteRule ^ajax/ - [L,NC]

# =========================================================
# PROTECT UPLOADS DIRECTORY (Multiple layers)
# =========================================================
RewriteRule ^uploads/.*\.(php|phtml|php3|php4|php5|php7|phar|inc)$ - [F,L,NC]

# =========================================================
# BLOCK ACCESS TO INTERNAL DIRECTORIES
# =========================================================
RewriteRule ^(vendor|config|includes|logs|cache|tmp|cron|backups)/ - [F,L,NC]

# =========================================================
# STATIC ASSETS (Allow direct access)
# =========================================================
RewriteRule \.(css|js|jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf|eot|map)$ - [L,NC]

# =========================================================
# EXISTING FILES/DIRECTORIES (Serve directly)
# =========================================================
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# =========================================================
# CLEAN URLS (Protected routes first)
# =========================================================

# Homepage
RewriteRule ^$ index.php [L]

# Authentication (protected)
RewriteRule ^login/?$ login.php [L,NC]
RewriteRule ^register/?$ register.php [L,NC]
RewriteRule ^logout/?$ logout.php [L,NC]
RewriteRule ^forgot-password/?$ forgot-password.php [L,NC]
RewriteRule ^reset-password/?$ reset-password.php [L,NC]

# Dashboard & Reports (protected)
RewriteRule ^dashboard/?$ dashboard.php [L,NC]
RewriteRule ^reports/?$ reports.php [L,NC]

# Academic (protected)
RewriteRule ^classes/?$ classes.php [L,NC]
RewriteRule ^students/?$ students.php [L,NC]
RewriteRule ^teachers/?$ teachers.php [L,NC]
RewriteRule ^subjects/?$ subjects.php [L,NC]
RewriteRule ^grading/?$ grading.php [L,NC]
RewriteRule ^exams/?$ exams.php [L,NC]
RewriteRule ^scores/?$ scores.php [L,NC]

# Blog (public - SEO allowed)
RewriteRule ^blog/?$ blog.php [L,NC]
RewriteRule ^blog/([a-zA-Z0-9-]+)/?$ blog.php?slug=$1 [L,QSA,NC]

# Products (public marketing pages)
RewriteRule ^exam-generator/?$ exam-generator.php [L,NC]
RewriteRule ^mwalimu-ai/?$ mwalimu-ai.php [L,NC]

# Public marketing/informational pages ONLY
RewriteRule ^features/?$ features.php [L,NC]
RewriteRule ^pricing/?$ pricing.php [L,NC]
RewriteRule ^contact/?$ contact.php [L,NC]
RewriteRule ^about/?$ about.php [L,NC]

# =========================================================
# REMOVE .PHP FROM PUBLIC URLS (301 Redirect)
# =========================================================
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Internal: Add .php extension back
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# =========================================================
# LIGHTWEIGHT SQL INJECTION DETECTION (Secondary defense only)
# Real protection must be in PHP with prepared statements
# =========================================================
RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} base64_encode[^(]*\([^)]*\) [OR]
RewriteCond %{QUERY_STRING} (\.\./|\.\.\\) [NC,OR]
RewriteCond %{QUERY_STRING} union(\+|%20)select [NC]
RewriteRule .* - [F,L]
RewriteRule ^sitemap\.xml$ /sitemap.php [L]

# =========================================================
# GZIP COMPRESSION
# =========================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript application/json
</IfModule>

# =========================================================
# BROWSER CACHING (Expires headers)
# =========================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# =========================================================
# ERROR PAGES
# =========================================================
ErrorDocument 403 /403.php
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php